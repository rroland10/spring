# Testnet nodeos compose — copy to .env and fill secrets (never commit .env)
#
# Prebuilt image (after GHA completes):
#   SIKA_NODEOS_IMAGE=ghcr.io/rroland10/sikachain-nodeos:sikachain-dev-sika-v2
#
# Local build instead:
#   SIKA_NODEOS_IMAGE=sikachain-nodeos:testnet
#   docker compose build

SIKA_NODEOS_IMAGE=ghcr.io/rroland10/sikachain-nodeos:sikachain-dev-sika-v2

# Host path to genesis.json (gen-testnet-keys.sh output); up.sh sets this automatically
SIKA_GENESIS_HOST=../../config/testnet/generated/genesis.json

# Use 8890 when dev chain already occupies 8888 (local dry-run)
# RPC_HOST_PORT=8890
# P2P_HOST_PORT=9877
# SHIP_HOST_PORT=8081

PRODUCER_NAME=sikabpa
# Use EOS legacy format in signature-provider (nodeos accepts PUB_K1 via key-format.mjs in up.sh)
SIGNATURE_PROVIDER=PUB_K1_REPLACE=KEY:5KREPLACE
P2P_ADVERTISE=bp1.testnet.sikachain.gh:9876
P2P_PEERS=
CORS_ORIGIN=https://app.sikachain.gh
AGENT_NAME=sikachain-testnet-bp1
