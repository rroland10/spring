# Fly.io — SikaChain testnet block producer (example)
# Copy to fly.toml and customize before `fly deploy`.
#
# Prebuilt image (after GHA tag push):
#   image = "ghcr.io/rroland10/sikachain-nodeos:sikachain-dev-sika-v3"
# Or build from Dockerfile on deploy (slower):
#   fly apps create sikachain-testnet-bp1
#   fly volumes create sikachain_data --region iad --size 50
#   fly secrets set SIGNATURE_PROVIDER='PUB_K1_xxx=KEY:5K...'
#   fly deploy

app = "sikachain-testnet-bp1"
primary_region = "iad"

[build]
  dockerfile = "sikachaindev/deploy/testnet/Dockerfile.nodeos"

[env]
  PRODUCER_NAME = "sikabpa"
  P2P_ADVERTISE = "sikachain-testnet-bp1.fly.dev:9876"
  P2P_PEERS = ""
  CORS_ORIGIN = "https://app.sikachain.gh"
  AGENT_NAME = "sikachain-testnet-bp1"
  HTTP_VALIDATE_HOST = "true"

# SIGNATURE_PROVIDER via fly secrets (never commit private keys)

[http_service]
  internal_port = 8888
  force_https = true
  auto_stop_machines = false
  auto_start_machines = true
  min_machines_running = 1
  processes = ["app"]

[[services]]
  protocol = "tcp"
  internal_port = 9876
  processes = ["app"]

  [[services.ports]]
    port = 9876
    handlers = []

[[services]]
  protocol = "tcp"
  internal_port = 8080
  processes = ["app"]

  [[services.ports]]
    port = 8080
    handlers = []

[mounts]
  source = "sikachain_data"
  destination = "/var/lib/sikachain/data"

[[vm]]
  memory = "4gb"
  cpu_kind = "shared"
  cpus = 2
