# Hyperion indexer/API for SikaChainDev (Linux — node-abieos native module).
FROM ubuntu:24.04

RUN apt-get update && \
    apt-get install -y --no-install-recommends ca-certificates curl && \
    curl -fsSL https://deb.nodesource.com/setup_24.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /hyperion

COPY hyperion-history-api/package.json hyperion-history-api/package-lock.json ./
RUN npm ci --ignore-scripts

COPY hyperion-history-api/ ./
RUN npm run build && npm run fix-permissions
